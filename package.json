{
  "name": "hardlogger",
  "version": "1.2.1",
  "description": "Beautiful, colorful dev-only logging for Node.js and Browser with zero configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 0",
    "manual:test": "bun tests/manual.test.ts && bun tests/multiple-args.test.ts",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "logger",
    "logging",
    "dev",
    "development",
    "console",
    "color",
    "colors",
    "pretty",
    "terminal",
    "browser",
    "node",
    "typescript",
    "bun",
    "nextjs",
    "express",
    "debug",
    "ansi",
    "styled",
    "zero-config",
    "dev-tools",
    "react",
    "vite",
    "developer",
    "developer-tools",
    "terminal-logger"
  ],
  "author": "Rudra Narayan Boitei (@rudranboitei)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rudranboitei/hardlogger.git"
  },
  "bugs": {
    "url": "https://github.com/rudranboitei/hardlogger/issues"
  },
  "homepage": "https://github.com/rudranboitei/hardlogger#readme",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
